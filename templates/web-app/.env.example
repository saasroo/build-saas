# =============================================================================
# Fireact Web App — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# Firebase Configuration
# Get these from Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Stripe Configuration (Frontend — publishable key only)
# Get from Stripe Dashboard → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# App Configuration
VITE_APP_NAME=Your App Name
VITE_APP_URL=http://localhost:5000

# =============================================================================
# The following are configured in functions/src/config/ files, not here:
# - Stripe Secret Key → stripe.config.json
# - Stripe Webhook Secret → stripe.config.json
# - Subscription Plans → stripe.config.json
# - Firebase Admin SDK → auto-configured in Cloud Functions
# - OAuth Provider Secrets → Firebase Console
# =============================================================================
